{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://2cec.aspro.cloud/api/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
